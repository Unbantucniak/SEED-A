{
  "name": "self-evolution-agent",
  "displayName": "自学习自演化智能体助手",
  "description": "基于经验积累的智能开发助手，支持经验自动积累、复用与演化",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "self-evolution-agent.searchExperience",
        "title": "智能助手：搜索相关开发经验"
      },
      {
        "command": "self-evolution-agent.saveCurrentExperience",
        "title": "智能助手：保存当前交互为经验"
      },
      {
        "command": "self-evolution-agent.showExperienceLibrary",
        "title": "智能助手：打开经验库面板"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "self-evolution-agent",
          "title": "智能开发助手",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "self-evolution-agent": [
        {
          "type": "webview",
          "id": "self-evolution-agent.experienceView",
          "name": "经验库"
        }
      ]
    },
    "configuration": {
      "title": "自学习自演化智能助手",
      "properties": {
        "self-evolution-agent.apiEndpoint": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "后端服务接口地址"
        },
        "self-evolution-agent.autoSaveExperience": {
          "type": "boolean",
          "default": true,
          "description": "是否自动保存成功的交互为经验"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "16.x",
    "typescript": "^5.1.3",
    "eslint": "^8.41.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2"
  },
  "dependencies": {
    "axios": "^1.4.0"
  }
}
